# ─── Omni-BugTracker configuration (env overrides config.yaml) ───
# Every key in config.yaml is overridable via OMNI_BT_<SECTION>__<KEY> (double underscore = nesting).

# Server
OMNI_BT_SERVER__ADDR=:8080
OMNI_BT_SERVER__BASE_URL=http://localhost:8080

# Postgres (source of truth + River job queue + FTS)
DATABASE_URL=postgres://omni:omni@localhost:5432/omni_bugtracker?sslmode=disable
OMNI_BT_DATABASE__MAX_CONNS=20

# Redis (cache + rate limiting only — NOT the job queue)
REDIS_URL=redis://localhost:6379/0

# Omni-Identity (only identity provider; we are a resource server)
OMNI_BT_IDENTITY__ISSUER=https://id.omni.dev
OMNI_BT_IDENTITY__JWKS_URL=https://id.omni.dev/.well-known/jwks.json
OMNI_BT_IDENTITY__AUDIENCE=omni-bugtracker

# Omni services (adapters; disable to run in degraded mode)
OMNI_BT_INTEGRATIONS__NOTIFY__BASE_URL=http://omni-notify:8080
OMNI_BT_INTEGRATIONS__NOTIFY__ENABLED=true
OMNI_BT_INTEGRATIONS__SEARCH__BASE_URL=http://omni-search:8080
OMNI_BT_INTEGRATIONS__SEARCH__ENABLED=true
OMNI_BT_INTEGRATIONS__UPLOAD__BASE_URL=http://omni-upload:8080
OMNI_BT_INTEGRATIONS__UPLOAD__ENABLED=true
OMNI_BT_INTEGRATIONS__LOGGING__ENABLED=true
OMNI_BT_INTEGRATIONS__METRICS__ENABLED=true

# Inbound webhook signing secrets (git provider / logging / metrics)
OMNI_BT_INTEGRATIONS__GIT__WEBHOOK_SECRET=change-me
OMNI_BT_INTEGRATIONS__LOGGING__WEBHOOK_SECRET=change-me
OMNI_BT_INTEGRATIONS__METRICS__WEBHOOK_SECRET=change-me

# ─── Deploy: docker-compose host published-port overrides ───
# Consumed by deploy/docker-compose.yml (NOT the app config above). The stack's
# published host ports are overridable so a self-hosted box avoids colliding with
# other services (a host Postgres on 5432, another service on 8080, ...). Compose
# falls back to dev defaults (5432 / 6379 / 8080 / 3000) when these are unset, so
# a prod box that leaves them unset will clash. Uncomment and set for prod —
# e.g. the omni host runs on:
#OMNI_BT_PG_PORT=15432
#OMNI_BT_REDIS_PORT=16379
#OMNI_BT_API_PORT=8092
#OMNI_BT_WEB_PORT=3002
